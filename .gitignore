# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel


# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
test
prompt

server.log
# Skills directory
/skills/
# Internal uploads — not for public repo
/upload/

# Preview screenshots — internal only
/download/*.png
/download/preview-sections/
/download/preview-viewport/
/download/avatar-sections/

# Local SQLite database (use Postgres in production)
/db/*.db
/db/*.db-journal

# Runtime PID files
.zscripts/*.pid
